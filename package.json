{
  "name": "@erick/aws-client",
  "version": "0.1.0",
  "description": "AWS service client library with typed interfaces",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.1032.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1032.0",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@opensearch-project/opensearch": "^2.13.0"
  }
}
